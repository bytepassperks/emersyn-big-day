<linker>
  <!-- Preserve game assemblies -->
  <assembly fullname="EmersynsBigDay" preserve="all"/>
  <assembly fullname="EmersynsBigDay.MiniGames" preserve="all"/>
  <assembly fullname="EmersynsBigDay.AI" preserve="all"/>

  <!-- Preserve GLTFast assemblies (still used as fallback) -->
  <assembly fullname="glTFast" preserve="all"/>
  <assembly fullname="glTFast.Runtime" preserve="all"/>

  <!-- Preserve Unity core assemblies - CRITICAL for runtime Mesh/Material creation -->
  <assembly fullname="UnityEngine.CoreModule" preserve="all"/>
  <assembly fullname="UnityEngine.PhysicsModule" preserve="all"/>
  <assembly fullname="UnityEngine.UI" preserve="all"/>
  <assembly fullname="UnityEngine.UIModule" preserve="all"/>
  <assembly fullname="UnityEngine.TextRenderingModule" preserve="all"/>
  <assembly fullname="UnityEngine.IMGUIModule" preserve="all"/>
  <assembly fullname="UnityEngine.AnimationModule" preserve="all"/>
  <assembly fullname="UnityEngine.AudioModule" preserve="all"/>
  <assembly fullname="UnityEngine.ParticleSystemModule" preserve="all"/>
  <assembly fullname="UnityEngine.ImageConversionModule" preserve="all"/>
  <assembly fullname="UnityEngine.UnityWebRequestModule" preserve="all"/>
  <assembly fullname="UnityEngine.UnityWebRequestTextureModule" preserve="all"/>
  <assembly fullname="UnityEngine.JSONSerializeModule" preserve="all"/>

  <!-- Round 36: Explicitly preserve Mesh/Material/MeshFilter/MeshRenderer for runtime GLB parsing -->
  <assembly fullname="UnityEngine">
    <type fullname="UnityEngine.Mesh" preserve="all"/>
    <type fullname="UnityEngine.MeshFilter" preserve="all"/>
    <type fullname="UnityEngine.MeshRenderer" preserve="all"/>
    <type fullname="UnityEngine.Material" preserve="all"/>
    <type fullname="UnityEngine.Shader" preserve="all"/>
    <type fullname="UnityEngine.Rendering.IndexFormat" preserve="all"/>
  </assembly>

  <!-- Preserve JSON serialization -->
  <assembly fullname="Newtonsoft.Json" preserve="all"/>
  <assembly fullname="Unity.Mathematics" preserve="all"/>
</linker>
